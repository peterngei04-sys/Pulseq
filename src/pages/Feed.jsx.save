import { useEffect, useState } from "react";
import { supabase } from "../lib/supabase";
import { useNavigate } from "react-router-dom";
import "../styles/global.css";

export default function Feed() {

  const navigate = useNavigate();

  const [session, setSession] = useState(null);
  const [profile, setProfile] = useState(null);

  const [posts, setPosts] = useState([]);
  const [loading, setLoading] = useState(true);

  const [showModal, setShowModal] = useState(false);
  const [activePost, setActivePost] = useState(null);

  const [comments, setComments] = useState({});
  const [newComment, setNewComment] = useState("");

  const [newTitle, setNewTitle] = useState("");
  const [newBody, setNewBody] = useState("");
  const [newType, setNewType] = useState("general");

  const [search, setSearch] = useState("");
  const [voting, setVoting] = useState(null);

  const [toast, setToast] = useState(null);

  /* TIME AGO */
  const timeAgo = (date) => {
    const seconds = Math.floor((new Date() - new Date(date)) / 1000);
    let interval = seconds / 3600;
    if (interval > 24) return Math.floor(interval / 24) + "d ago";
    if (interval > 1) return Math.floor(interval) + "h ago";
    interval = seconds / 60;
    if (interval > 1) return Math.floor(interval) + "m ago";
    return Math.floor(seconds) + "s ago";
  };

  /* TOAST HELPER */
  const showToast = (message) => {
    setToast(message);
    setTimeout(() => setToast(null), 3000);
  };

  /* SESSION */
  useEffect(() => {
    const loadSession = async () => {
      const { data } = await supabase.auth.getSession();
      const sess = data.session;

      setSession(sess);

      if (sess) {
        const { data: profileData } = await supabase
          .from("profiles")
          .select("username")
          .eq("id", sess.user.id)
          .single();
        setProfile(profileData);
      }
    };
    loadSession();
  }, []);

  /* FETCH POSTS */
  const fetchPosts = async () => {
    setLoading(true);
    const { data, error } = await supabase
      .from("posts")
      .select(`
        id,
        user_id,
        title,
        body,
        upvotes,
        comment_count,
        created_at,
        profiles!posts_user_id_fkey(username)
      `)
      .order("upvotes", { ascending: false })
      .order("created_at", { ascending: false });

    if (error) {
      console.log(error);
      setLoading(false);
      return;
    }

    const formatted = data.map((p) => ({
      ...p,
      username: p.profiles?.username || "User",
    }));

    setPosts(formatted);
    setLoading(false);
  };

  useEffect(() => { fetchPosts(); }, []);

  
         
  /* REALTIME POSTS */
  useEffect(() => {
    const channel = supabase
      .channel("realtime-posts")
      .on(
        "postgres_changes",
        { event: "*", schema: "public", table: "posts" },
        () => fetchPosts()
      )
      .subscribe();

    return () => supabase.removeChannel(channel);
  }, []);

  /* LOGOUT */
  const handleLogout = async () => {
    await supabase.auth.signOut();
    navigate("/login");
  };

  /* DELETE POST */
  const handleDeletePost = async (postId) => {
    if (!session) return;

    // Remove window.confirm, auto delete with toast
    const { error } = await supabase
      .from("posts")
      .delete()
      .eq("id", postId)
      .eq("user_id", session.user.id);

    if (error) {
      console.log(error);
      return;
    }

    showToast("🗑 Post deleted");
    fetchPosts();
  };

  /* VOTE */
  const handleVote = async (postId) => {
    if (!session) return;
    if (voting === postId) return;

    setVoting(postId);

    const { data: existing } = await supabase
      .from("votes")
      .select("id")
      .eq("post_id", postId)
      .eq("user_id", session.user.id)
      .single();

    if (existing) {
      setVoting(null);
      return;
    }

    setPosts((prev) =>
      prev.map((post) =>
        post.id === postId
          ? { ...post, upvotes: (post.upvotes || 0) + 1 }
          : post
      )
    );

    const { error } = await supabase.from("votes").insert({
      post_id: postId,
      user_id: session.user.id,
      value: 1,
    });

    if (error) {
      console.log(error);
      fetchPosts();
    } else {
      showToast("🔥 Upvoted");
    }

    setTimeout(() => setVoting(null), 800);
  };

  /* FETCH COMMENTS */
  const fetchComments = async (postId) => {
    const { data, error } = await supabase
      .from("comments")
      .select(`
        id,
        content,
        profiles!comments_user_id_fkey(username)
      `)
      .eq("post_id", postId)
      .order("created_at", { ascending: true });

    if (error) return;

    const formatted = data.map((c) => ({
      ...c,
      username: c.profiles?.username || "User",
    }));

    setComments((prev) => ({
      ...prev,
      [postId]: formatted,
    }));
  };

  /* ADD COMMENT */
  const handleAddComment = async (postId) => {
    if (!newComment.trim() || !session) return;

    await supabase.from("comments").insert({
      post_id: postId,
      user_id: session.user.id,
      content: newComment,
    });

    setNewComment("");
    await fetchComments(postId);
    await fetchPosts();
    showToast("💬 Comment added");
  };

  /* CREATE POST */
  const handlePost = async (e) => {
    e.preventDefault();
    if (!session) return;

    await supabase.from("posts").insert({
      title: newTitle,
      body: newBody,
      post_type: newType,
      user_id: session.user.id,
    });

    setNewTitle("");
    setNewBody("");
    setShowModal(false);
    fetchPosts();
    showToast("✅ Post published");
  };

  /* FILTER POSTS */
  const filteredPosts = posts.filter((post) => {
    const term = search.toLowerCase();
    return (
      post.title?.toLowerCase().includes(term) ||
      post.body?.toLowerCase().includes(term) ||
      post.username?.toLowerCase().includes(term)
    );
  });

  /* UI */
  return (
    <div className="feed-wrapper">

      <header className="top-header">
        <h2>PulseQ</h2>
        <div style={{ display: "flex", gap: "10px", alignItems: "center" }}>
          <div className="profile-btn" onClick={() => navigate("/profile")}>
            {profile?.username ? profile.username.charAt(0).toUpperCase() : "👤"}
          </div>
          <button className="logout-btn" onClick={handleLogout}>Logout</button>
        </div>
      </header>

      <div className="search-bar">
        <input
          type="text"
          placeholder="Search posts, people, ideas..."
          value={search}
          onChange={(e) => setSearch(e.target.value)}
        />
       <button className="refresh-btn" onClick={fetchPosts}>⟳ Refresh</button>
          
    </div>

      <div className="posts-area">
        {loading && Array.from({ length: 5 }).map((_, i) => (
          <div key={i} className="skeleton-card"></div>
        ))}

        {filteredPosts.length === 0 && !loading && (
          <div className="no-posts">
            No posts found — start the conversation 🚀
          </div>
        )}

        {filteredPosts.map((post) => (
          <div
            key={post.id}
            className={`modern-card ${post.upvotes > 5 ? "trending" : ""} show`}
            onDoubleClick={() => handleVote(post.id)}
          >
            <div className="card-top">
              <div className="avatar">
                {post.username?.charAt(0).toUpperCase()}
              </div>
              <span className="username">
                {post.username} • {timeAgo(post.created_at)}
              </span>
              {post.upvotes > 5 && <span className="trend-label">🔥 Trending</span>}
            </div>

            <h3 className="modern-title">{post.title}</h3>
            <p className="modern-body">{post.body}</p>

            <div className="card-actions">
              <button
                onClick={() => handleVote(post.id)}
                className={`action-btn ${voting === post.id ? "voted" : ""}`}
              >
                🔥 {post.upvotes || 0}
              </button>

              <button
                onClick={() => {
                  setActivePost(post.id);
                  fetchComments(post.id);
                }}
                className="action-btn"
              >
                💬 {post.comment_count || 0}
              </button>

              {session?.user?.id === post.user_id && (
                <button
                  onClick={() => handleDeletePost(post.id)}
                  className="action-btn"
                >
                  🗑
                </button>
              )}
            </div>

            {activePost === post.id && (
              <div className="comment-drawer">
                {comments[post.id]?.map((c) => (
                  <div key={c.id} className="comment-item">
                    <strong>{c.username}</strong>
                    <p>{c.content}</p>
                  </div>
                ))}

                <div className="comment-input">
                  <input
                    value={newComment}
                    onChange={(e) => setNewComment(e.target.value)}
                    placeholder="Write a reply..."
                  />
                  <button onClick={() => handleAddComment(post.id)}>Send</button>
                </div>
              </div>
            )}

          </div>
        ))}
      </div>

      <div className="fab" onClick={() => setShowModal(true)}>+</div>

      {showModal && (
        <div className="modal-overlay">
          <form className="modal-content" onSubmit={handlePost}>
            <h3>Create Post</h3>
            <input
              placeholder="Title"
              value={newTitle}
              onChange={(e) => setNewTitle(e.target.value)}
              required
            />
            <textarea
              placeholder="What's happening?"
              value={newBody}
              onChange={(e) => setNewBody(e.target.value)}
              required
            />
            <select
              value={newType}
              onChange={(e) => setNewType(e.target.value)}
            >
              <option value="general">General</option>
              <option value="hot_take">Hot Take</option>
              <option value="question">Question</option>
            </select>
            <button type="submit">Post</button>
            <span className="close-modal" onClick={() => setShowModal(false)}>Cancel</span>
          </form>
        </div>
      )}

      {/* TOAST NOTIFICATION */}
      {toast && <div className="toast">{toast}</div>}

    </div>
  );
}

  /* CREATE POST */
  const handlePost = async (e) => {
    e.preventDefault();
    if (!session) return;

    await supabase.from("posts").insert({
      title: newTitle,
      body: newBody,
      post_type: newType,
      user_id: session.user.id,
    });

    setNewTitle("");
    setNewBody("");
    setShowModal(false);
    fetchPosts();
    showToast("✅ Post published");
  };

  /* FILTER POSTS */
  const filteredPosts = posts.filter((post) => {
    const term = search.toLowerCase();
    return (
      post.title?.toLowerCase().includes(term) ||
      post.body?.toLowerCase().includes(term) ||
      post.username?.toLowerCase().includes(term)
    );
  });

  /* UI */
  return (
    <div className="feed-wrapper">

      <header className="top-header">
        <h2>PulseQ</h2>
        <div style={{ display: "flex", gap: "10px", alignItems: "center" }}>
          <div className="profile-btn" onClick={() => navigate("/profile")}>
            {profile?.username ? profile.username.charAt(0).toUpperCase() : "👤"}
          </div>
          <button className="logout-btn" onClick={handleLogout}>Logout</button>
        </div>
      </header>

      <div className="search-bar">
        <input
          type="text"
          placeholder="Search posts, people, ideas..."
          value={search}
          onChange={(e) => setSearch(e.target.value)}
        />
       <button className="refresh-btn" onClick={fetchPosts}>⟳ Refresh</button>

    </div>

      <div className="posts-area">
        {loading && Array.from({ length: 5 }).map((_, i) => (
          <div key={i} className="skeleton-card"></div>
        ))}

        {filteredPosts.length === 0 && !loading && (
          <div className="no-posts">
            No posts found — start the conversation 🚀
          </div>
        )}

        {filteredPosts.map((post) => (
          <div
            key={post.id}
            className={`modern-card ${post.upvotes > 5 ? "trending" : ""} show`}
            onDoubleClick={() => handleVote(post.id)}
          >
            <div className="card-top">
              <div className="avatar">
                {post.username?.charAt(0).toUpperCase()}
              </div>
              <span className="username">
                {post.username} • {timeAgo(post.created_at)}
              </span>
              {post.upvotes > 5 && <span className="trend-label">🔥 Trending</span>}
            </div>

            <h3 className="modern-title">{post.title}</h3>
            <p className="modern-body">{post.body}</p>

            <div className="card-actions">
              <button
                onClick={() => handleVote(post.id)}
                className={`action-btn ${voting === post.id ? "voted" : ""}`}
              >
                🔥 {post.upvotes || 0}
              </button>

              <button
                onClick={() => {
                  setActivePost(post.id);
                  fetchComments(post.id);
                }}
                className="action-btn"
              >
                💬 {post.comment_count || 0}
              </button>

              {session?.user?.id === post.user_id && (
                <button
                  onClick={() => handleDeletePost(post.id)}
                  className="action-btn"
                >
                  🗑
                </button>
              )}
            </div>
